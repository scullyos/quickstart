# ScullyOS Quickstart — top-level environment.
# Edit values here to override defaults. Service-specific overrides live
# in env/<service>.env.

# SET YOUR VALUES HERE

# ─── Seed admin user ─────────────────────────────────────────────────────────
# The first user the platform knows about. Created by the
# BootstrapAdminPassword migration on first boot of person-ms.
# `SEED_USER_NAME` becomes the login email; `SEED_USER_PASSWORD` becomes
# the credential. Change BEFORE the first `up -d` to set a custom value;
# changes afterwards have no effect (migration is idempotent).
SEED_USER_FIRST_NAME=ScullyOS
SEED_USER_LAST_NAME=Demo
SEED_USER_NAME=your-email-here@scullyos.ai
SEED_USER_PASSWORD=ChangeMeImmediately!1

# ─── bo-orc agent (LLM) ─────────────────────────────────────────────
# The Admin agent chat panel is ON by default. Set USE_AGENT=no to turn
# it off entirely (then no LLM_API_KEY is needed and the rest of the
# platform still works).
USE_AGENT=yes
#
# With the agent on, it needs a valid LLM_API_KEY to respond. The
# placeholder below lets the stack boot; replace it with your own key to
# use the agent (don't leave it blank — an empty key fails validation).
#
# Your key never leaves this machine. It's read by your local bo-orc
# container and used to call the LLM provider directly. The platform
# does not phone home and does not relay your key anywhere.
#
# NOTE: Default LLM_PROVIDER is google (set below) using their free tier.
# You can swap it with Anthropic, see below.
#
LLM_API_KEY=replace-with-your-llm-api-key

# ─── LLM provider for the LLM_API_KEY above ─────────────────────────────
# Google (default): get a key at https://aistudio.google.com/apikey
LLM_PROVIDER=google
# Free tier model, paid versions can use gemini-3.1-flash
LLM_MODEL=gemini-2.5-flash

#
# Anthropic alternative — uncomment and replace the two lines above (and api key at the top):
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-haiku-4-5-20251001
#   LLM_API_KEY=sk-ant-api03-...
#
# Local / OpenAI-compatible alternative (Ollama, LM Studio, vLLM, …):
#   LLM_PROVIDER=openai-compatible
#   LLM_MODEL=llama3.1:70b-instruct
#   LLM_API_KEY=ollama
#   plus set LLM_BASE_URL in quickstart/env/bo-orc.env (see that file for why
#   it lives there and for the host.docker.internal networking note).


# ─── Kibana login ────────────────────────────────────────────────────────────
# These are the credentials you type into the Kibana login page at
# http://localhost:${HOST_PORT_KIBANA}. Mechanically: a superuser of this
# name is created in Elasticsearch by setup/es-setup.sh on first boot,
# replaces the built-in `elastic` user (which is then disabled), and is
# what Kibana logs into ES as. The same password is also used as the ES
# `elastic` bootstrap password during that one-time setup.
KIBANA_USERNAME=scullyos
KIBANA_PASSWORD=changeme-kibana-password

# ─── Browser-facing ports ────────────────────────────────────────────────────
# Defaults are in the 1xxxx range to avoid Mac AirPlay / Windows IIS / common
# dev-server collisions. Override here if you have a local conflict.
HOST_PORT_FRONTEND=18080
HOST_PORT_BO_ORC=18001
HOST_PORT_KIBANA=15601

# ─── MySQL ───────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=12345678
# DB_USERNAME / DB_PASSWORD / DB_DATABASE_NAME match the values the MSs
# already expect; do not change without also updating env/*.env.
MYSQL_APPUSER=appuser
MYSQL_APP_PASSWORD=12345678
MYSQL_DATABASE=main_db

# ─── Seed admin user (extra) ─────────────────────────────────────────────────────────
# By default we use a local auth mechanism, if you want firebase, this is the place to change
# This will require other firebase realted env vars.
SEED_USER_PROVIDER=local

# ─── Fluent Bit ──────────────────────────────────────────────────────────────
# Comma-separated container-name regex; logs from any container whose
# container_name matches this regex are shipped to Elasticsearch.
# Default ships only the three platform microservices. Extend to include
# your own containers, e.g. "^(person|authorization|bo-orc)-ms$|^my-app$".
FLUENT_BIT_CONTAINER_INCLUDE_REGEX=^(person|authorization|bo-orc)-ms$

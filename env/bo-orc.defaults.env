# bo-orc-ms — quickstart defaults snapshot.
#
# Compose-ready. Edit bo-orc.env (sibling file) to override.
# Source of truth: ../bo-orc/config/.env.development.

# ─── Component identity ──────────────────────────────────────────────────────
COMPONENT_TYPE=orc
COMPONENT_TITLE=BO Orchestrator
COMPONENT_DESC=Backoffice orchestrator for the FE to call
COMPONENT_AUTH=none
COMPONENT_NAME=bo-orc
COMPONENT_VERSION=0.0.1
PACKAGES_GROUP=@onthebits

# ─── Tooling ─────────────────────────────────────────────────────────────────
PORT=8001
RUNTIME_TYPE=container
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
USE_DB=yes
ORM_IMPL=typeorm
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
META_DB_DATABASE_NAME=information_schema
DB_LOG_MODE=all
INVALID_CON_FAIL_POOL_ON_STARTUP=yes
DB_DATASOURCE_NAME=default
META_CONNECTION_POOL_SIZE=1
META_KEEP_ALIVE_INITIAL_DELAY_MS=10000
CONNECTION_POOL_SIZE=5
KEEP_ALIVE_INITIAL_DELAY_MS=10000
ROOT_DB_USERNAME=root

# ─── Logging ─────────────────────────────────────────────────────────────────
LOGGER_IMPL=log4js
LOGGER_MSG_FORMAT=object
#LOGGER_MSG_FORMAT=text
#LOGGER_TEXT_FORMAT_PATTERN=[msReqId:{msreqid}] {message}, errorStack: {errorStack}, {entityType}:{entityId}, traceId:{traceId}, spanId:{spanId}, context:{context}, {ms}
LOG4JS_LOGGER_CONF_FILE=config/log4js.k8s.conf.json


# Log redaction (added by simple-core 0.0.28).
# Master switch — 'no' disables both Pass 1 (key-pattern scrub) and Pass 2
# (PII content scan), including per-call scanForPii: true. Local-debug only.
LOGGER_IS_MASKING=yes
# Marker substituted in for redacted values.
LOGGER_MASKING_REPLACEMENT=[REDACTED]
# Comma-separated extra key names woven into Pass 1 (additive only, names only;
# regex syntax is rejected). Example: session_id,csrf_token
LOGGER_MASKING_EXTRA_KEYS=
# Always run Pass 2 (PII content scan) even without per-call scanForPii: true.
LOGGER_IS_PII_MASKING_DEFAULT=no

# ─── Audit ───────────────────────────────────────────────────────────────────
USE_AUDIT=yes
AUDIT_LOG_VERBOSE=no
SERVICE_REQUEST_AUDIT_TABLE=bo_orc_request_audit

# ─── Person client ───────────────────────────────────────────────────────────
# 30s instead of 5s: bo-orc-db-init runs its seed-admin migration before
# person-ms / authorization-ms have had a chance to warm their DB pools and
# audit interceptor (cold-path can hit ~7s on a fresh stack). 30s tolerates
# that worst case while still surfacing a real hang.
PERSON_CLIENT_TIMEOUT=30000
PERSON_MS_URL_BASE=http://person-ms:84
PERSON_MS_URI_BASE=/v1/person
PERSON_USE_IDEMPOTENCY=yes

# ─── Attribute client (talks to person-ms) ───────────────────────────────────
ATTRIBUTE_MS_URL_BASE=http://person-ms:84
ATTRIBUTE_DATA_MS_URI_BASE=/v1/attribute
ATTRIBUTE_MS_URI_BASE=/v1/attribute-metadata
ATTRIBUTE_CLIENT_TIMEOUT=30000
ATTRIBUTE_USE_IDEMPOTENCY=yes

# ─── Tag client (talks to person-ms) ─────────────────────────────────────────
TAG_MS_URL_BASE=http://person-ms:84
TAG_DATA_MS_URI_BASE=/v1/tag
TAG_MS_URI_BASE=/v1/tag-metadata
TAG_CLIENT_TIMEOUT=30000
TAG_USE_IDEMPOTENCY=yes

# ─── Authorization client ────────────────────────────────────────────────────
AUTHORIZATION_MS_URL_BASE=http://authorization-ms:81
AUTHORIZATION_MS_URI_BASE=/v1/authorization
AUTHORIZATION_CLIENT_TIMEOUT=30000
AUTHORIZATION_USE_IDEMPOTENCY=yes

# ─── Eventing (off in quickstart) ────────────────────────────────────────────
IS_PUBLISHER=no
USE_LOCALSTACK=no
CLOUD_PROVIDER=aws
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=fake
AWS_SECRET_ACCESS_KEY=fake

# ─── CORS / inter-service auth ───────────────────────────────────────────────
# CORS open in quickstart — the SPA reaches bo-orc on a different host port
# than the SPA itself (e.g. 18001 vs 18080).
CORS_ORIGIN=*
SCULLYOS_TOKEN_JWT_SECRET=CHANGE_ME_GENERATE_NEW_32_BYTE_HEX
USE_FWD_ATTR_HEADERS=yes
IDEMPOTENCY_HEADER_KEY_NAME=X-SCULLYOS-IDEMPOTENCY-KEY

# ─── APM / OTel (off in quickstart) ──────────────────────────────────────────
USE_APM=no

# ─── Agent / Chat ────────────────────────────────────────────────────────────
# LLM_PROVIDER, LLM_MODEL, LLM_API_KEY are forwarded from quickstart/.env
# at compose-up time. Empty LLM_API_KEY = ChatModule is not loaded
# (bo-orc app.module.ts gates on it); the rest of the stack still works.
AGENT_MCP_SERVERS=person,authorization
LLM_MAX_STEPS=10
AGENT_ENGINE=langgraph
AGENT_CHECKPOINTER=memory
AGENT_SESSION_TTL_SECONDS=7200
AGENT_SYSTEM_PROMPTS_FILE=config/agent-system-prompts.json
AGENT_HIGH_STAKES_TOOLS=person_invite,person_delete
LOG_AGENT_PAYLOADS=yes

JWT_PRIVATE_KEY_PATH=./config/dev-keys/jwt-private-dev.pem
JWT_TOKEN_TTL_SECONDS=3600
JWT_ISSUER_EXPECTED=bo-orc

USE_SPACE=no
USE_SEARCH=no
ADDRESS_MS_URL_BASE=http://person-ms:84
ADDRESS_DATA_MS_URI_BASE=/v1/address
ADDRESS_MS_URI_BASE=/v1/address-metadata

ADDRESS_CLIENT_TIMEOUT=5000
ADDRESS_USE_IDEMPOTENCY=yes

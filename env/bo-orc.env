# bo-orc-ms — your overrides.
#
# Loaded AFTER bo-orc.defaults.env. LLM_PROVIDER / LLM_MODEL / LLM_API_KEY
# come from quickstart/.env via compose `environment:` — set them there,
# not here.
#
# Examples:
#   LOG_AGENT_PAYLOADS=no                       # quieter agent logs
#   AGENT_HIGH_STAKES_TOOLS=person_invite,...   # extend HITL gating
#   AGENT_CHECKPOINTER=redis  + REDIS_URL=...   # persistent agent state

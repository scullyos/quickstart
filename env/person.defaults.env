# person-ms — quickstart defaults snapshot.
#
# Compose-ready. Edit person.env (sibling file) to override anything here
# without touching this snapshot. This file is the platform's notion of
# "sane defaults for the quickstart"; person.env is your machine.
#
# Source of truth: ../person/config/.env.development in the monorepo.
# Differences from the monorepo version are commented inline.

# ─── Component identity ──────────────────────────────────────────────────────
COMPONENT_TYPE=ms
COMPONENT_TITLE=Person service
COMPONENT_DESC=People-management service for the platform.
PACKAGES_GROUP=@onthebits

# ─── Tooling ─────────────────────────────────────────────────────────────────
ORM_IMPL=typeorm
PORT=84
NODE_OPTIONS=--dns-result-order=ipv4first
RUNTIME_TYPE=container
# ConfigServiceFactory throws "NODE_ENV not set, config cant be set" without
# this. Matches the value k8s configmaps use for the dev/in-cluster deploy.
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# DB_HOST=mysql here (compose service name) instead of 127.0.0.1.
# DB_USERNAME / DB_PASSWORD / DB_DATABASE_NAME are forwarded from
# quickstart/.env via compose `environment:` so they're not duplicated here.
USE_DB=yes
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
META_DB_DATABASE_NAME=information_schema
DB_LOG_MODE=all
INVALID_CON_FAIL_POOL_ON_STARTUP=yes
DB_DATASOURCE_NAME=default
CONNECTION_POOL_SIZE=5
KEEP_ALIVE_INITIAL_DELAY_MS=10000
META_CONNECTION_POOL_SIZE=1
META_KEEP_ALIVE_INITIAL_DELAY_MS=10000
ROOT_DB_USERNAME=root

# ─── Logging ─────────────────────────────────────────────────────────────────
# Points at log4js.k8s.conf.json (the file actually shipped in the image —
# the local-dev log4js.conf.json is not in the runtime image).
LOGGER_IMPL=log4js
LOGGER_MSG_FORMAT=object
#LOGGER_MSG_FORMAT=text
#LOGGER_TEXT_FORMAT_PATTERN=[msReqId:{msreqid}] {message}, errorStack: {errorStack}, {entityType}:{entityId}, traceId:{traceId}, spanId:{spanId}, context:{context}, {ms}
LOG4JS_LOGGER_CONF_FILE=config/log4js.k8s.conf.json


# Log redaction (added by simple-core 0.0.28).
# Master switch — 'no' disables both Pass 1 (key-pattern scrub) and Pass 2
# (PII content scan), including per-call scanForPii: true. Local-debug only.
LOGGER_IS_MASKING=yes
# Marker substituted in for redacted values.
LOGGER_MASKING_REPLACEMENT=[REDACTED]
# Comma-separated extra key names woven into Pass 1 (additive only, names only;
# regex syntax is rejected). Example: session_id,csrf_token
LOGGER_MASKING_EXTRA_KEYS=
# Always run Pass 2 (PII content scan) even without per-call scanForPii: true.
LOGGER_IS_PII_MASKING_DEFAULT=no

# ─── Event publishing ────────────────────────────────────────────────────────
# Disabled in the quickstart — Cloud is not part of this stack.
IS_PUBLISHER=no

# ─── AWS / Localstack (off in quickstart) ────────────────────────────────────
USE_LOCALSTACK=no
CLOUD_PROVIDER=other

# ─── Auth provider ───────────────────────────────────────────────────────────
# Local first. To switch to Firebase: set AUTH_PROVIDER=firebase,
# PERSON_SERVICE_IMPL=firebase, ship a Firebase service-account JSON, and
# point FIREBASE_KEY_FILE at it.
AUTH_PROVIDER=local
PERSON_SERVICE_IMPL=internal
PERSON_ATTRIBUTE_TABLE=person_attribute
PERSON_ATTRIBUTE_METADATA_TABLE=person_attribute_metadata

# ─── Local auth provider — JWT ───────────────────────────────────────────────
# CHANGE_ME on first deploy. Generate with: openssl rand -hex 32
LOCAL_PROVIDER_JWT_SECRET=CHANGE_ME_GENERATE_NEW_32_BYTE_HEX
LOCAL_PROVIDER_JWT_KID=local-1
LOCAL_PROVIDER_JWT_TTL_SECONDS=300

# ─── Local auth provider — methods + password policy ─────────────────────────
AUTH_METHODS=password
LOCAL_GOOGLE_NONCE_TTL_SECONDS=300
AUTH_METHOD_PASSWORD_MIN_LENGTH=12
AUTH_METHOD_PASSWORD_REQUIRE_MIXED_CASE=true
AUTH_METHOD_PASSWORD_REQUIRE_DIGIT=true
AUTH_METHOD_PASSWORD_REQUIRE_SYMBOL=false

# ─── Person rules ────────────────────────────────────────────────────────────
PERSON_ENFORCE_UNIQUE_KEYS=email,phoneNumber
PERSON_SIGNUP_DEFAULT_TYPE=user

# ─── Audit ───────────────────────────────────────────────────────────────────
SERVICE_REQUEST_AUDIT_TABLE=person_request_audit
USE_AUDIT=yes
AUDIT_LOG_VERBOSE=yes

# ─── Person client (self-reference; URLs forwarded from quickstart/.env) ─────
USE_IDEMPOTENCY=yes
IDEMPOTENCY_HEADER_KEY_NAME=X-SCULLYOS-IDEMPOTENCY-KEY
PERSON_CLIENT_TIMEOUT=5000
PERSON_USE_IDEMPOTENCY=yes
PERSON_MS_URL_BASE=http://person-ms:84
PERSON_MS_URI_BASE=/v1/person

# ─── Attributes / Tags ───────────────────────────────────────────────────────
USE_ATTRIBUTES=yes
ATTRIBUTE_METADATA_TABLE_NAME=person_attribute_metadata
ATTRIBUTE_TABLE_NAME=person_attribute
USE_TAGS=yes
TAG_METADATA_TABLE_NAME=person_tag_metadata
TAG_TABLE_NAME=person_tag

# ─── APM / OTel (off in quickstart) ──────────────────────────────────────────
USE_APM=no

# ─── MCP ─────────────────────────────────────────────────────────────────────
MCP_ENABLED=yes
MCP_PATH=/mcp
MCP_SERVER_NAME=person-mcp
MCP_SERVER_VERSION=0.0.1
MCP_PROMPTS_FILE=config/mcp-prompts.json
MCP_STRICT_PERMISSIONS=strict
MCP_SKIP_PATHS=/test/ready,/auth
# bo-orc's agent discovers tools on this MS's /mcp endpoint over the
# compose network (non-loopback). Without this, mcp-core rejects with
# "MCP endpoint accepts loopback connections only".
MCP_BIND_PUBLIC=yes

JWT_ISSUER_EXPECTED=scullyos-orc,bo-orc
JWT_PUBLIC_KEY_SOURCE=bundled-dev
JWT_AUTH_MODE=enforce

USE_ADDRESSES=yes
ADDRESS_METADATA_TABLE_NAME=person_address_metadata
ADDRESS_TABLE_NAME=person_address

# scullyosapp — quickstart defaults snapshot.
#
# Compose-ready. Edit scullyosapp.env (sibling file) to override.
# Source of truth: ../scullyosapp/.env (in the monorepo).
#
# These are runtime values injected into window.__env__ at container
# start by /entrypoint.sh. Browser-side URLs (VITE_BO_ORC_MS_URL_BASE,
# VITE_LOGGING_URL) are forwarded from quickstart/.env via compose
# `environment:` so they're not duplicated here.

# ─── Feature flags ───────────────────────────────────────────────────────────
VITE_FEATURE_PEOPLE=true
VITE_FEATURE_AUTHORIZATION=true
VITE_FEATURE_SPACES=false
VITE_FEATURE_EMAIL=false
VITE_FEATURE_FILES=false
VITE_FEATURE_LEGAL=false
VITE_FEATURE_FEATURE_FLAGS=false
VITE_FEATURE_CICD=false
VITE_FEATURE_LOGGING=true
VITE_FEATURE_OBSERVABILITY=false

# ─── People page tuning ──────────────────────────────────────────────────────
VITE_PERSON_SHOW_OPTIONAL_ATTRIBUTES=true

# ─── Idle logout (ms) ────────────────────────────────────────────────────────
VITE_IDLE_LOGOUT_MS=7200000
VITE_IDLE_LOGOUT_GRACE_MS=60000

VITE_LOGGING_URL=http://127.0.0.1:15601/app/discover

# ─── Marketing (unused-service "Pro" cards + upgrade banner) ─────────────────
# Shown by default so evaluators can sign up for the full version. Set
# VITE_HIDE_MARKETING=true to remove all of it. VITE_ENV is intentionally left
# unset (no environment banner competing with the signup pitch; unset is treated
# as non-production so marketing still shows).
VITE_HIDE_MARKETING=false
VITE_MARKETING_SIGNUP_URL=https://scullyos.ai/signup
VITE_MARKETING_SOURCE=quickstart
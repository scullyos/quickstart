# scullyosapp — your overrides.
#
# Loaded AFTER scullyosapp.defaults.env. URLs (VITE_BO_ORC_MS_URL_BASE,
# VITE_LOGGING_URL) are derived from HOST_PORT_* in quickstart/.env via
# compose `environment:` — change host ports there, not here.
#
# Examples:
#   VITE_FEATURE_SPACES=true            # enable a subsystem flag
#   VITE_FIREBASE_API_KEY=AIza...       # opt back into Firebase auth
#   VITE_FIREBASE_AUTH_DOMAIN=...
#   VITE_FIREBASE_PROJECT_ID=...

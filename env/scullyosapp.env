# scullyosapp — your overrides.
#
# Loaded AFTER scullyosapp.defaults.env. URLs (VITE_BO_ORC_MS_URL_BASE,
# VITE_LOGGING_URL) are derived from HOST_PORT_* in quickstart/.env via
# compose `environment:` — change host ports there, not here.
#
# Examples:
#   VITE_FEATURE_SPACES=true            # enable a subsystem flag
#   VITE_FIREBASE_API_KEY=AIza...       # opt back into Firebase auth
#   VITE_FIREBASE_AUTH_DOMAIN=...
#   VITE_FIREBASE_PROJECT_ID=...

# Marketing (Pro cards + upgrade banner) is configured in
# scullyosapp.defaults.env (shown by default, signup → scullyos.ai,
# utm_source=quickstart). Override here:
#   VITE_HIDE_MARKETING=true                       # remove all marketing
#   VITE_MARKETING_SIGNUP_URL=https://scullyos.ai/signup
#   VITE_MARKETING_SOURCE=quickstart               # utm_source tag
#   VITE_ENV=production                            # also hides marketing + banner
